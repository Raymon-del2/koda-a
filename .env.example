# ============================================
# KODA-A ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your actual API keys
# DO NOT commit .env.local to GitHub!
# ============================================

# ============================================
# AI / LLM APIs
# ============================================
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ============================================
# YouTube Data API v3
# Get from: https://console.cloud.google.com/apis/credentials
# ============================================
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================
# TMDB (The Movie Database) API
# Get from: https://www.themoviedb.org/settings/api
# ============================================
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================
# NewsAPI
# Get from: https://newsapi.org/account
# ============================================
NEWS_API_KEY=your_newsapi_key_here

# ============================================
# Qdrant Vector Database (Cloud)
# Get from: https://cloud.qdrant.io/keys
# ============================================
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# ============================================
# Firebase - Koda Project
# Get from: https://console.firebase.google.com/project/koda-021/settings/general
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=koda-021.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=koda-021
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=koda-021.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# Firebase - Bxarchi Project (Optional)
# Get from: https://console.firebase.google.com/project/bxarchi-10a7d/settings/general
# ============================================
NEXT_PUBLIC_BXARCHI_FIREBASE_API_KEY=your_bxarchi_api_key
NEXT_PUBLIC_BXARCHI_FIREBASE_AUTH_DOMAIN=bxarchi-10a7d.firebaseapp.com
NEXT_PUBLIC_BXARCHI_FIREBASE_PROJECT_ID=bxarchi-10a7d
NEXT_PUBLIC_BXARCHI_FIREBASE_STORAGE_BUCKET=bxarchi-10a7d.firebasestorage.app
NEXT_PUBLIC_BXARCHI_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_BXARCHI_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_BXARCHI_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# Vercel (Auto-populated by Vercel CLI)
# Do not manually set these - Vercel handles them
# ============================================
# VERCEL_OIDC_TOKEN= (auto-set by Vercel)
